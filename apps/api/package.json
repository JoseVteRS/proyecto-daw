    "helmet": "^8.1.0",
    "jose": "^6.2.3",
    "pg": "8.16.3",
    "pino": "^10.3.1",
    "pinojs": "^2.0.9"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "22.19.19",
    "@types/pg": "8.15.6",
    "pino-pretty": "^13.1.3",
